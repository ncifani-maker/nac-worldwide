---
const currentPath = Astro.url.pathname;
---

<header>
  <div class="container">
    <a href="/" class="logo">
      <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <polygon points="20,2 38,38 2,38" fill="#0a0a0a"/>
        <polygon points="20,10 32,34 8,34" fill="#ffffff"/>
        <polygon points="20,18 28,34 12,34" fill="#0a0a0a"/>
      </svg>
      <span>NAC Worldwide</span>
    </a>
    <nav>
      <a href="/" class:list={[{ active: currentPath === '/' }]}>Home</a>
      <a href="/contact-us" class="cta-button">Let's Go</a>
    </nav>
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
    z-index: 100;
    padding: 1rem 0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-weight: 600;
    font-size: 1.1rem;
    letter-spacing: -0.02em;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  nav a {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--gray);
    transition: color 0.2s;
  }

  nav a:hover, nav a.active {
    color: var(--black);
  }

  .cta-button {
    background: var(--black) !important;
    color: var(--white) !important;
    padding: 0.5rem 1.25rem;
    border-radius: 6px;
    font-weight: 600 !important;
    transition: opacity 0.2s !important;
  }

  .cta-button:hover {
    opacity: 0.85;
  }
</style>
