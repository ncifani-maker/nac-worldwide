---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact — NAC Worldwide" description="Interested in working together? Get in touch with NAC Worldwide.">
  <Header />

  <main>
    <section class="contact">
      <div class="container">
        <div class="contact-grid">
          <div class="contact-text">
            <p class="eyebrow">Get In Touch</p>
            <h1>Let's Get<br />To Work</h1>
            <p class="subtext">Interested in working together? Fill out some info and we will be in touch shortly.</p>
            <div class="contact-details">
              <a href="mailto:contact@nac-worldwide.com">contact@nac-worldwide.com</a>
              <a href="tel:3104608098">(310) 460-8098</a>
              <span>San Francisco, CA</span>
            </div>
          </div>

          <form class="contact-form" name="contact" method="POST" data-netlify="true">
            <input type="hidden" name="form-name" value="contact" />
            <div class="field">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" placeholder="Your name" required />
            </div>
            <div class="field">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="you@company.com" required />
            </div>
            <div class="field">
              <label for="company">Company</label>
              <input type="text" id="company" name="company" placeholder="Company name" />
            </div>
            <div class="field">
              <label for="message">What are you working on?</label>
              <textarea id="message" name="message" rows="5" placeholder="Tell us about your growth goals..." required></textarea>
            </div>
            <button type="submit">Send Message</button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .contact {
    padding: 6rem 0 7rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: start;
  }

  .eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 1rem;
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
  }

  .subtext {
    font-size: 1rem;
    color: var(--gray);
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact-details a,
  .contact-details span {
    font-size: 0.9rem;
    color: var(--gray);
    transition: color 0.2s;
  }

  .contact-details a:hover {
    color: var(--black);
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--black);
  }

  input, textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-family: inherit;
    font-size: 0.95rem;
    color: var(--black);
    background: var(--white);
    transition: border-color 0.2s;
    resize: vertical;
  }

  input::placeholder, textarea::placeholder {
    color: #9ca3af;
  }

  input:focus, textarea:focus {
    outline: none;
    border-color: var(--black);
  }

  button[type="submit"] {
    background: var(--black);
    color: var(--white);
    border: none;
    padding: 0.9rem 2rem;
    border-radius: 8px;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s;
    align-self: flex-start;
  }

  button[type="submit"]:hover {
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
