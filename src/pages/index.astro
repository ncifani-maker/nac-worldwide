---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Header />

  <main class="nacw">

    <!-- HERO -->
    <section class="nacw-hero">
      <div class="nacw-wrap">
        <h1>Your <span class="nacw-accent-text">AI-Powered</span><br/>Marketing Partner.</h1>
        <p>AI moves fast. Models change weekly. Tools update hourly. Your team doesn't have time to stay on top of it while also hitting plan. I do.</p>
        <p>I'm Nicole — a senior marketing operator. I bring my experience and an entire stack of AI-powered agents into your organization as one hire. You get modern marketing. I keep you on the frontier.</p>
        <div class="nacw-cta">
          <a href="#nacw-cta" class="nacw-btn nacw-btn-primary">Book a call</a>
          <a href="#nacw-tiers" class="nacw-btn nacw-btn-secondary">See how it works</a>
        </div>
      </div>
    </section>

    <!-- PRESS -->
    <section class="nacw-press">
      <div class="nacw-wrap">
        <span class="nacw-press-label">As seen in</span>
        <div class="nacw-press-logos">
          <img src="/fast-company.svg" alt="Fast Company" class="nacw-press-logo" />
        </div>
      </div>
    </section>

    <!-- SHIFT -->
    <section class="nacw-shift">
      <div class="nacw-wrap">
        <div class="nacw-kicker">Why you're here</div>
        <h2>The AI world is moving faster than your marketing team can.</h2>
        <p>The frontier shifts every week. A new creative model. A new targeting approach. A new agent framework that replaces a process you built last quarter. In-house teams can't keep up and still ship. Agencies are eighteen months behind.</p>
        <p>NAC lives at the frontier. I operate like a senior CMO. The agent stack underneath me operates like a team of ten. You get both as one subscription — and you stop worrying about being the last marketing org that didn't get the memo.</p>
      </div>
    </section>

    <!-- NICOLE -->
    <section class="nacw-nicole" id="nacw-nicole">
      <div class="nacw-wrap">
        <div class="nacw-nicole-grid">
          <div class="nacw-nicole-photo">
            <img src="/001-F1ABeFxYiak.jpeg" alt="Nicole Lehmann-Haupt, founder of NAC Worldwide" />
          </div>
          <div>
            <h2>Hi, I'm Nicole.</h2>
            <p>I've spent the last decade running marketing for venture-backed companies — fintech, SaaS, consumer. I've built teams, owned P&Ls, shipped campaigns, survived growth audits, and reported to boards.</p>
            <p>Then AI happened. Like everyone else, I watched the tools shift under my feet. Unlike everyone else, I rebuilt my marketing practice on top of them. NAC is what that looks like — a services firm rebuilt on software infrastructure, where agents handle the execution and I handle the judgment.</p>
            <p>I take on a small number of clients at a time. I pick engagements I know I can win. And I'm the face of every one of them.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- TIERS -->
    <section class="nacw-tiers" id="nacw-tiers">
      <div class="nacw-wrap">
        <div class="nacw-section-intro">
          <div class="nacw-kicker">What you get</div>
          <h2>Three ways in.</h2>
          <p>Every tier is one senior operator + an AI stack that runs like a team. One contract. No surprise invoices.</p>
        </div>
        <div class="nacw-tier-grid">

          <div class="nacw-tier">
            <h3>Embedded</h3>
            <div class="nacw-tier-bestfor">Seed / early Series A</div>
            <div class="nacw-tier-price">Starting at $10K/mo<small>3-month minimum</small></div>
            <p>Nicole as your fractional senior operator. 1–2 agents deployed against your highest-leverage channel. Monthly strategy, weekly async reviews, live dashboard access.</p>
            <p>For founders who already have someone running marketing but need senior judgment and an AI layer.</p>
            <a href="#nacw-cta" class="nacw-btn nacw-btn-secondary">Book a call</a>
          </div>

          <div class="nacw-tier featured">
            <h3>Department</h3>
            <div class="nacw-tier-bestfor">Series A–B</div>
            <div class="nacw-tier-price">Let's talk<small>6-month minimum</small></div>
            <p>The core engagement. Nicole runs marketing as a function. Full agent stack — creative, paid, partner ops, lifecycle, attribution, forecasting. Ongoing execution. Weekly ops reviews. Board-grade reporting.</p>
            <p>The senior marketing hire and the team of six, delivered as a subscription.</p>
            <a href="#nacw-cta" class="nacw-btn nacw-btn-primary">Book a call</a>
          </div>

          <div class="nacw-tier">
            <h3>Frontier</h3>
            <div class="nacw-tier-bestfor">Series B–C</div>
            <div class="nacw-tier-price">Let's talk<small>12-month minimum</small></div>
            <p>Department plus custom agent development for your stack, quarterly AI audits, direct access to Nicole, and a dedicated junior operator on your account.</p>
            <p>For companies where marketing is the engine — consumer brands, fintech, SaaS where every point of CAC matters.</p>
            <a href="#nacw-cta" class="nacw-btn nacw-btn-secondary">Book a call</a>
          </div>

        </div>
      </div>
    </section>

    <!-- STACK -->
    <section class="nacw-stack" id="nacw-stack">
      <div class="nacw-wrap">
        <div class="nacw-section-intro">
          <div class="nacw-kicker">Under the hood</div>
          <h2>Agents that do the work.</h2>
          <p>The reason a partner costs less than a hire is the stack. Here's what's running inside every engagement.</p>
        </div>
        <div class="nacw-stack-grid">
          <div class="nacw-stack-card">
            <div class="nacw-icon">AO</div>
            <h4>Ad Optimizations</h4>
            <p>Continuous bid strategy, audience refinement, and budget reallocation across Meta, Google, and TikTok.</p>
          </div>
          <div class="nacw-stack-card">
            <div class="nacw-icon">PO</div>
            <h4>Partner Ops Agent</h4>
            <p>Affiliate recruiting, outreach, and health monitoring on autopilot.</p>
          </div>
          <div class="nacw-stack-card">
            <div class="nacw-icon">OD</div>
            <h4>Operator Dashboard</h4>
            <p>Your live view of pipeline, spend, and outcomes. Log in any time.</p>
          </div>
          <div class="nacw-stack-card">
            <div class="nacw-icon">CE</div>
            <h4>Content Engine</h4>
            <p>AI-assisted content strategy, briefs, and copy — built around your brand voice and shipped on a cadence.</p>
          </div>
          <div class="nacw-stack-card">
            <div class="nacw-icon">CR</div>
            <h4>Creative Development</h4>
            <p>AI-accelerated briefs, copy variants, and structured testing frameworks. More signal per dollar — at any budget level.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- PROOF -->
    <section class="nacw-proof">
      <div class="nacw-wrap">
        <div class="nacw-section-intro">
          <div class="nacw-kicker">Proof</div>
          <h2>Outcomes, not logos.</h2>
        </div>
        <div class="nacw-proof-grid">
          <div class="nacw-proof-card">
            <div class="nacw-metric">3x pipeline<br/>in 90 days</div>
          </div>
          <div class="nacw-proof-card">
            <div class="nacw-metric">30% lower CAC<br/>while scaling paid</div>
          </div>
          <div class="nacw-proof-card">
            <div class="nacw-metric">Top affiliate<br/>channel in 60 days</div>
          </div>
        </div>
        <div class="nacw-proof-clients">
          Puzzle.io &middot; Keepsafe &middot; Brain.fm &middot; OneNotary &middot; UNAGI &middot; Thistle &middot; MATRIX Powerwatch &middot; Oui Shave &middot; Homeaglow
        </div>
      </div>
    </section>

    <!-- PRICING EXPLAIN -->
    <section class="nacw-pricing-explain">
      <div class="nacw-wrap">
        <h2>Flat monthly. No hourly. No surprise invoices.</h2>
        <p>Embedded starts at $10K/month. Department and Frontier are priced based on the scope of your marketing function. Every engagement starts with a 2-week AI Audit — $5,000, credited back against your first month.</p>
        <p>One contract. Cancel with 30 days' notice.</p>
        <a href="#nacw-cta" class="nacw-btn nacw-btn-primary">Start with the AI Audit</a>
      </div>
    </section>

    <!-- AUDIT -->
    <section class="nacw-audit">
      <div class="nacw-wrap">
        <div class="nacw-audit-card">
          <h2>Not sure yet? Start with the AI Audit.</h2>
          <p>Two weeks. $5,000. I plug my stack into your ad accounts, CRM, and analytics, run a diagnosis, and return with a written forecast of what Embedded, Department, or Frontier would deliver for you — with real numbers.</p>
          <p>If you hire me, the $5K credits against your first month. If you don't, you keep the diagnosis.</p>
          <a href="#nacw-cta" class="nacw-btn nacw-btn-primary">Book the AI Audit</a>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="nacw-finalcta" id="nacw-cta">
      <div class="nacw-wrap">
        <h2>Let's work together.</h2>
        <p>If you want a senior marketing operator, a modern AI stack, and one point of accountability — let's talk. I take a small number of clients per quarter. Engagements start with a 30-minute call.</p>
        <div class="nacw-cta">
          <a href="/contact-us" class="nacw-btn nacw-btn-primary">Book a call</a>
          <a href="/contact-us" class="nacw-btn nacw-btn-secondary">Get the AI Audit</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  .nacw {
    --ink: #0d1117;
    --muted: #5b6474;
    --line: #e5e7eb;
    --bg: #ffffff;
    --bg-alt: #f6f7f9;
    --accent: #2E75B6;
    --accent-light: #7eb6e6;
    --warm: #f1ece3;
    font-family: 'Inter', system-ui, sans-serif;
    color: var(--ink);
    line-height: 1.55;
  }

  .nacw-wrap {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .nacw-kicker {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    color: var(--accent);
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  /* Buttons */
  .nacw-btn {
    display: inline-block;
    padding: 14px 26px;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 600;
    font-size: 15px;
    letter-spacing: 0.02em;
    transition: all 0.15s ease;
    border: 1px solid transparent;
  }
  .nacw-btn-primary { background: var(--ink); color: #fff; border-color: var(--ink); }
  .nacw-btn-primary:hover { background: var(--accent); border-color: var(--accent); }
  .nacw-btn-secondary { background: transparent; color: var(--ink); border-color: var(--ink); }
  .nacw-btn-secondary:hover { background: var(--ink); color: #fff; }

  /* HERO */
  .nacw-hero {
    background: linear-gradient(180deg, #0d1117 0%, #1a2030 100%);
    color: #fff;
    padding: 120px 0 100px;
  }
  .nacw-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.05;
    margin: 0 0 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #fff;
  }
  .nacw-accent-text { color: var(--accent-light); }
  .nacw-hero p { font-size: 1.1rem; color: #c9d3e0; max-width: 680px; margin: 0 0 1rem; }
  .nacw-hero .nacw-cta { margin-top: 2rem; display: flex; gap: 14px; flex-wrap: wrap; }
  .nacw-hero .nacw-btn-primary { background: #fff; color: var(--ink); border-color: #fff; }
  .nacw-hero .nacw-btn-primary:hover { background: var(--accent-light); border-color: var(--accent-light); }
  .nacw-hero .nacw-btn-secondary { color: #fff; border-color: #c9d3e0; }
  .nacw-hero .nacw-btn-secondary:hover { background: #fff; color: var(--ink); }

  /* PRESS */
  .nacw-press {
    background: var(--bg);
    border-bottom: 1px solid var(--line);
    padding: 36px 0;
  }
  .nacw-press .nacw-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }
  .nacw-press-label {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 600;
  }
  .nacw-press-logos {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .nacw-press-logo {
    height: 50px;
    width: auto;
    width: auto;
    opacity: 0.6;
    filter: grayscale(1);
    transition: opacity 0.2s;
  }
  .nacw-press-logo:hover { opacity: 0.85; }

  /* SHIFT */
  .nacw-shift { padding: 110px 0; background: var(--bg); border-bottom: 1px solid var(--line); }
  .nacw-shift h2 { font-size: clamp(1.75rem, 4vw, 2.75rem); line-height: 1.15; margin: 0 0 1.25rem; font-weight: 800; letter-spacing: -0.01em; max-width: 880px; }
  .nacw-shift p { font-size: 1.1rem; color: #2a3340; max-width: 820px; margin: 0 0 1rem; }

  /* NICOLE */
  .nacw-nicole { background: var(--warm); padding: 110px 0; }
  .nacw-nicole-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 60px; align-items: center; }
  .nacw-nicole-photo {
    aspect-ratio: 4/5;
    background: #d6cfc0;
    border-radius: 6px;
    overflow: hidden;
  }
  .nacw-nicole-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .nacw-nicole h2 { font-size: clamp(1.75rem, 3vw, 2.4rem); line-height: 1.15; margin: 0 0 1.25rem; font-weight: 800; letter-spacing: -0.01em; }
  .nacw-nicole p { font-size: 1rem; color: #2a3340; margin: 0 0 1rem; }

  /* SECTION INTRO */
  .nacw-section-intro { text-align: center; max-width: 720px; margin: 0 auto 3.5rem; }
  .nacw-section-intro h2 { font-size: clamp(1.75rem, 3.5vw, 2.5rem); line-height: 1.15; margin: 0 0 1rem; font-weight: 800; letter-spacing: -0.01em; }
  .nacw-section-intro p { font-size: 1.05rem; color: var(--muted); margin: 0; }

  /* TIERS */
  .nacw-tiers { padding: 110px 0; background: var(--bg); border-bottom: 1px solid var(--line); }
  .nacw-tier-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .nacw-tier {
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 40px 30px 36px;
    display: flex;
    flex-direction: column;
    background: #fff;
    position: relative;
  }
  .nacw-tier.featured { border-color: var(--ink); box-shadow: 0 14px 40px rgba(13,17,23,0.08); }
  .nacw-tier.featured::before {
    content: "MOST COMMON";
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--ink);
    color: #fff;
    padding: 5px 14px;
    font-size: 11px;
    letter-spacing: 0.15em;
    font-weight: 700;
    border-radius: 3px;
  }
  .nacw-tier h3 { font-size: 1.6rem; margin: 0 0 6px; font-weight: 800; }
  .nacw-tier-bestfor { font-size: 11px; letter-spacing: 0.14em; color: var(--accent); font-weight: 700; text-transform: uppercase; margin-bottom: 1rem; }
  .nacw-tier-price { font-size: 1.2rem; font-weight: 700; margin-bottom: 1rem; }
  .nacw-tier-price small { display: block; font-size: 11px; color: var(--muted); font-weight: 400; letter-spacing: 0.04em; margin-top: 4px; }
  .nacw-tier p { font-size: 0.9rem; color: #3a4452; margin: 0 0 1rem; line-height: 1.55; }
  .nacw-tier .nacw-btn { width: 100%; text-align: center; margin-top: auto; }

  /* STACK */
  .nacw-stack { padding: 110px 0; background: var(--bg-alt); }
  .nacw-stack-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 18px; }
  .nacw-stack-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 26px 22px;
    display: flex;
    flex-direction: column;
    min-height: 200px;
  }
  .nacw-icon {
    width: 36px; height: 36px;
    border-radius: 6px;
    background: var(--ink);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 12px;
    margin-bottom: 1rem;
  }
  .nacw-stack-card h4 { font-size: 1rem; margin: 0 0 8px; font-weight: 700; }
  .nacw-stack-card p { font-size: 0.8rem; color: var(--muted); margin: 0; line-height: 1.5; }

  /* PROOF */
  .nacw-proof { padding: 110px 0; background: var(--bg); border-bottom: 1px solid var(--line); }
  .nacw-proof-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 1.25rem; }
  .nacw-proof-card { border-left: 3px solid var(--accent); padding: 18px 0 18px 24px; }
  .nacw-metric { font-size: 1.75rem; font-weight: 800; letter-spacing: -0.01em; margin-bottom: 10px; line-height: 1.15; }
  .nacw-desc { font-size: 0.875rem; color: var(--muted); line-height: 1.55; }
  .nacw-proof-clients {
    margin-top: 2.5rem;
    text-align: center;
    font-size: 0.8rem;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  /* PRICING EXPLAIN */
  .nacw-pricing-explain { padding: 90px 0; background: var(--ink); color: #fff; }
  .nacw-pricing-explain h2 { font-size: clamp(1.5rem, 3vw, 2.25rem); line-height: 1.2; margin: 0 0 1rem; font-weight: 800; letter-spacing: -0.01em; max-width: 820px; color: #fff; }
  .nacw-pricing-explain p { font-size: 1.05rem; color: #c9d3e0; max-width: 760px; margin: 0 0 0.875rem; }
  .nacw-pricing-explain .nacw-btn { margin-top: 1.5rem; }
  .nacw-pricing-explain .nacw-btn-primary { background: #fff; color: var(--ink); border-color: #fff; }
  .nacw-pricing-explain .nacw-btn-primary:hover { background: var(--accent-light); border-color: var(--accent-light); color: var(--ink); }

  /* AUDIT */
  .nacw-audit { padding: 90px 0; background: var(--warm); }
  .nacw-audit-card {
    background: #fff;
    border-radius: 10px;
    padding: 48px;
    max-width: 820px;
    margin: 0 auto;
    box-shadow: 0 14px 40px rgba(13,17,23,0.06);
  }
  .nacw-audit-card h2 { font-size: 1.875rem; margin: 0 0 14px; font-weight: 800; letter-spacing: -0.01em; }
  .nacw-audit-card p { font-size: 1rem; color: #2a3340; margin: 0 0 14px; }
  .nacw-audit-card .nacw-btn { margin-top: 1.25rem; }

  /* FINAL CTA */
  .nacw-finalcta { padding: 120px 0; background: var(--bg); text-align: center; }
  .nacw-finalcta h2 { font-size: clamp(2rem, 5vw, 3rem); margin: 0 0 1rem; font-weight: 800; letter-spacing: -0.02em; }
  .nacw-finalcta p { font-size: 1.1rem; color: var(--muted); max-width: 600px; margin: 0 auto 2rem; }
  .nacw-finalcta .nacw-cta { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .nacw-hero { padding: 80px 0 70px; }
    .nacw-shift, .nacw-tiers, .nacw-stack, .nacw-proof, .nacw-nicole, .nacw-finalcta { padding: 70px 0; }
    .nacw-tier-grid, .nacw-proof-grid { grid-template-columns: 1fr; }
    .nacw-stack-grid { grid-template-columns: repeat(2, 1fr); }
    .nacw-nicole-grid { grid-template-columns: 1fr; }
    .nacw-nicole-photo { aspect-ratio: 3/2; }
    .nacw-audit-card { padding: 32px 24px; }
  }
</style>
