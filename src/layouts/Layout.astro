---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "NAC Worldwide — Growth Marketing Agency",
  description = "Clear strategies for direct and actionable growth. Affiliate marketing, paid media strategy, and operator-level execution.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --black: #0a0a0a;
    --white: #ffffff;
    --gray: #6b7280;
    --light-gray: #f5f5f5;
    --border: #e5e7eb;
  }

  html {
    font-family: 'Inter', system-ui, sans-serif;
    color: var(--black);
    background: var(--white);
    scroll-behavior: smooth;
  }

  body {
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    display: block;
  }
</style>
